PORT=8787

# AI provider selection:
# - auto: prefer local MCP server when available, otherwise use Anthropic directly
# - mcp: force local MCP server
# - anthropic: force direct Anthropic API calls
AI_PROVIDER=auto

# Direct Anthropic fallback
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_TIMEOUT_MS=180000

# Local MCP server integration
MCP_SERVER_COMMAND=node
MCP_SERVER_PATH=../../MCP/dist/index.js
MCP_AUDIO_TOOL=audio_producer
MCP_TIMEOUT_MS=180000

AI_CACHE_TTL_MS=300000
AI_CACHE_MAX_ENTRIES=100
